# ---- Coding agent (Claude Code, headless, runs inside the sandbox) ----
# Anthropic key, or an AI Gateway key if you also set ANTHROPIC_BASE_URL.
ANTHROPIC_API_KEY=
# Optional: route the agent through Vercel AI Gateway.
# ANTHROPIC_BASE_URL=https://ai-gateway.vercel.sh
# AGENT_MODEL=claude-sonnet-4-5

# ---- The locked template repo the shell edits ----
TARGET_REPO_URL=https://github.com/owner/repo.git
TARGET_REPO_BRANCH=main

# ---- GitHub (clone private repos, push the session branch, open the PR) ----
# A fine-scoped token with contents:write + pull_requests:write on the target.
# Add email read access if you want Ivan to use the account's primary GitHub
# email for commits; otherwise it falls back to the account-owned noreply email.
GITHUB_TOKEN=

# ---- Vercel Sandbox credentials ----
# From the Vercel dashboard. (If omitted, the SDK can use VERCEL_OIDC_TOKEN from
# `vercel link` + `vercel env pull`, but explicit tokens are simplest.)
SANDBOX_VERCEL_TEAM_ID=
SANDBOX_VERCEL_PROJECT_ID=
SANDBOX_VERCEL_TOKEN=

# ---- Aiven MCP ----
# Gives the in-sandbox agent the Aiven MCP server so it can provision and
# inspect Aiven services live. Create a token in the Aiven Console; your org
# admin must enable Admin settings > Authentication > Allow MCP connection.
AIVEN_TOKEN=
# Write mode (false) lets the agent fork services and run migrations. Set to
# true to restrict it to non-destructive operations.
AIVEN_READ_ONLY=false
# Return real connection credentials so the agent can connect to a fork and run
# SQL. Dev/fork only; pair with a fork-scoped token that cannot reach prod.
AIVEN_ALLOW_SECRETS=true

# ---- Optional ----
# Public URL used in Slack workspace links. Its host is also allowlisted for
# Next dev resources when you run Ivan through ngrok or another tunnel.
# IVAN_APP_URL=
# NEXT_PUBLIC_APP_URL=
# Additional comma-separated hosts or URLs allowed to load Ivan's dev server.
# IVAN_ALLOWED_DEV_ORIGINS=

# Injected into the sandbox so full-stack changes / migrations hit a real DB.
# DATABASE_URL=
# SANDBOX_DEV_PORT=3000
# SANDBOX_TIMEOUT_MS=1800000

# ---- Demo mode ----
# A real Aiven fork takes ~5 min, longer than a 4-min demo, so we can't fork on
# stage. Pre-create a fork with the create-demo-fork skill, then set both values
# below (URL = its Postgres connection URI for the preview app; NAME = its Aiven
# service name for the proxy redirect). Setting them turns demo mode on: the
# agent still makes a real fork call (the audience sees it), but its Aiven MCP
# calls are transparently redirected onto this already-live fork. Both required
# together; leave unset for the real path.
# IVAN_DEMO_FORK_URL=
# IVAN_DEMO_FORK_NAME=coffee-database-demo-fork-1
# IVAN_DEMO_FORK_PROJECT=coloop
# Set true so the agent's fork-create is faked (no real throwaway to clean up).
# Recommended for repeated rehearsals; leave false for an honest end-to-end run.
# IVAN_DEMO_FAKE_CREATE=false

# ---- MCP trace mode ----
# Set true to run the in-sandbox Aiven MCP behind a logging proxy that records
# every JSON-RPC request/response to a trace file in the sandbox. Download it
# from GET /api/sessions/<id>/mcp-trace after a turn that used the Aiven MCP.
# The trace contains real connection credentials; handle it as a secret.
# IVAN_MCP_TRACE=false
